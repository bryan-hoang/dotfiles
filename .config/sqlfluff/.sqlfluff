# https://docs.sqlfluff.com/en/stable/reference/rules.html#ruleref

[sqlfluff]
dialect = tsql
exclude_rules = ambiguous.column_count, structure.column_order
large_file_skip_byte_limit = 65536
max_line_length = 120

[sqlfluff:indentation]
# See https://docs.sqlfluff.com/en/stable/perma/indent_locations.html
indent_unit = tab
tab_space_size = 4

[sqlfluff:rules:capitalisation.identifiers]
# Unquoted identifiers
extended_capitalisation_policy = upper

[sqlfluff:rules:convention.terminator]
require_final_semicolon = True

[sqlfluff:rules:layout.long_lines]
# Line length
ignore_comment_clauses = False
ignore_comment_lines = True

[sqlfluff:rules:references.special_chars]
# Allow special characters when making quoted aliases for columns.
quoted_identifiers_policy = table_aliases
