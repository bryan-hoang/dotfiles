amends "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  ["bom"] = Builtins.byte_order_marker
  ["check_add_large_files"] = Builtins.check_added_large_files
  ["check_case_conflict"] = Builtins.check_case_conflict
  ["check_executables_have_shebangs"] = Builtins.check_executables_have_shebangs
  ["check_merge_conflict"] = Builtins.check_merge_conflict
  ["check_symlinks"] = Builtins.check_symlinks
  ["detect_private_key"] = Builtins.detect_private_key
  ["editorconfig_checker"] = Builtins.editorconfig_checker
  ["fix_smart_quotes"] = Builtins.fix_smart_quotes
  ["mise"] = Builtins.mise
  ["ox_lint"] = Builtins.ox_lint
  ["ruff"] = Builtins.ruff
  ["ruff_format"] = Builtins.ruff_format
  ["rumdl"] = Builtins.rumdl
  ["shellcheck"] = Builtins.shellcheck
  ["shfmt"] = (Builtins.shfmt) {
    check = "shfmt -bn -ci --simplify {{ files }}"
  }
  ["sql_fluff"] = Builtins.sql_fluff
  ["taplo"] = Builtins.taplo
  ["taplo_format"] = Builtins.taplo_format
  ["zizmor"] = Builtins.zizmor

  ["betterleaks"] = (Builtins.gitleaks) {
    check = "betterleaks dir --redact --verbose --no-banner --log-level warn {{ files }}"
  }
  ["harper"] = (Builtins.harper) {
    exclude =
      List(
        "**/.bashrc",
        "**/dictionary.txt",
        "**/git/config",
        "*.cshtml",
        "*.css",
        "*.gitconfig",
        "*.json*",
        "*.pkl",
        "*.ps1",
        "*npmrc",
				"*.sql",
      )
  }
  ["lychee"] = (Builtins.lychee) {
    exclude = List("**/git/config", "**/opencode.json*")
  }
}

exclude = List("node_modules", "dist", "build")
hooks {
  ["pre-commit"] {
    fix = false
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
