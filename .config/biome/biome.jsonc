{
	// Local reference to avoid needing to updating the global version everywhere.
	"$schema": "https://raw.githubusercontent.com/biomejs/biome/refs/heads/main/packages/%40biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false,
	},
	"formatter": {
		"formatWithErrors": true,
	},
	"javascript": {
		"formatter": {
			// Match the common rule in more JS projects.
			"quoteStyle": "single",
		},
	},
}
