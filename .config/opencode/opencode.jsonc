{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"formatter": {
		"oxfmt": {
			"command": ["oxfmt", "$FILE"],
			"extensions": [".json", ".yaml", ".yml"],
		},
	},
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": ["bun", "x", "chrome-devtools-mcp@latest"],
		},
		"fff": {
			"type": "local",
			"command": ["fff-mcp"],
			"enabled": true,
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": true,
		},
		"pitchfork": {
			"type": "local",
			"command": ["pitchfork", "mcp"],
		},
	},
	"plugin": [],
}
