{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"lsp": {},
	"formatter": {
		"oxfmt": {
			"command": ["oxfmt", "$FILE"],
			"extensions": [".yaml", ".yml"],
		},
		"taplo": {
			"command": ["taplo", "format", "$FILE"],
			"extensions": [".toml"],
		},
	},
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": ["aube", "dlx", "chrome-devtools-mcp@latest"],
			"enabled": false,
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": false,
		},
		"fff": {
			"type": "local",
			"command": ["fff-mcp"],
			"enabled": true,
		},
		"obscura": {
			"type": "local",
			"command": ["obscura", "mcp"],
			"enabled": false,
		},
		"pitchfork": {
			"type": "local",
			"command": ["pitchfork", "mcp"],
			"enabled": false,
		},
		"mdn": {
			"type": "remote",
			"url": "https://mcp.mdn.mozilla.net/",
			"enabled": false,
		},
	},
	"plugin": ["@dietrichgebert/ponytail"],
	"permission": {
		"bash": {
			"rtk git push *": "deny",
			"cat *": "deny",
			"sed *": "deny",
			"rtk cat *": "deny",
			"rtk awk *": "deny",
			"find *": "deny",
			"Add-Content *": "deny",
			"Get-Content *": "deny",
			"pwsh -c *": "deny",
			"powershell -c *": "deny",
			"rtk read *": "deny",
			"echo *": "deny",
			"New-Item *": "deny",
			"Set-Content *": "deny",
			// `grep` & friends...
			"Select-String *": "deny",
			"findstr *": "deny",
			"grep *": "deny",
			"rtk grep *": "deny",
			"sls *": "deny",
			"type *": "deny",
			"node -e *": "deny",
			// `--target-branch` doesn't seem to work...
			"az repos pr create *": "deny",
		},
		"external_directory": {
			"~/AppData/Local/Temp/opencode/**": "allow",
		},
	},
}
