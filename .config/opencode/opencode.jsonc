{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": true,
	"formatter": {
		"oxfmt": {
			"command": [
				"oxfmt",
				"$FILE"
			],
			"extensions": [
				".md",
				".json",
				".yaml",
				".yml"
			]
		}
	},
	"mcp": {
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": true
		},
	}
}
