{
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": false,
	"formatter": {
		"oxfmt": {
			"command": ["oxfmt", "$FILE"],
			"extensions": [".yaml", ".yml"],
		},
	},
	"mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": ["aube", "dlx", "chrome-devtools-mcp@latest"],
			"enabled": true,
		},
		"fff": {
			"type": "local",
			"command": ["fff-mcp"],
			"enabled": true,
		},
		"exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": true,
		},
		"obscura": {
			"type": "local",
			"command": ["obscura", "mcp"],
			"enabled": false,
		},
		"pitchfork": {
			"type": "local",
			"command": ["pitchfork", "mcp"],
			"enabled": false,
		},
	},
	"plugin": [],
	"permission": {
		"bash": {
			"Get-Content *": "deny",
			"Select-String *": "deny",
			// `--target-branch` doesn't seem to work...
			"az repos pr create *": "deny",
			"cat *": "deny",
			"find *": "deny",
			"findstr *": "deny",
			"grep *": "deny",
			"rtk grep *": "deny",
			"pwsh -Command \"Get-Content *": "deny",
		},
		"external_directory": {
			"~/AppData/Local/Temp/opencode/**": "allow",
		},
	},
}
